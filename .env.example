# ── Database (Supabase) ───────────────────────────────────────────────────────
# Pooled connection — used at runtime (Vercel serverless)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection — used only for `prisma migrate deploy` (not needed at runtime)
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ── AI (DeepSeek) ─────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-chat"
# Optional: override DeepSeek base URL (default: https://api.deepseek.com)
# DEEPSEEK_BASE_URL="https://api.deepseek.com"
# Optional: model for embeddings (default: deepseek-embedding)
# DEEPSEEK_EMBEDDING_MODEL="deepseek-embedding"

# ── AI (OpenAI) — optional, not used in main chat flow ───────────────────────
OPENAI_API_KEY=""

# ── Embeddings ────────────────────────────────────────────────────────────────
# "auto"    = try DeepSeek embeddings, fall back to local hash-based embeddings
# "local"   = always use local hash embeddings (no API calls, free, lower quality)
# "deepseek"= always use DeepSeek embeddings (requires valid DEEPSEEK_API_KEY)
EMBEDDINGS_MODE="auto"
LOCAL_EMBEDDINGS_DIM="256"

# ── Search tuning ─────────────────────────────────────────────────────────────
RETRIEVE_TOP_K="8"
MIN_RELEVANCE="0.1"

# ── Translation (optional) ────────────────────────────────────────────────────
# Free tier: 5000 chars/day. Add email for 10000 chars/day.
MYMEMORY_EMAIL=""

# ── Admin ─────────────────────────────────────────────────────────────────────
# Required: set a strong random secret (min 32 chars recommended)
# Generate with: openssl rand -hex 32
ADMIN_SECRET="your-strong-random-secret-here"

# ── Chat access ───────────────────────────────────────────────────────────────
# Set to "true" to allow all visitors to use the AI chat (no admin login needed)
# Leave unset or set to "false" to restrict chat to admins only
NEXT_PUBLIC_CHAT_PUBLIC="false"
